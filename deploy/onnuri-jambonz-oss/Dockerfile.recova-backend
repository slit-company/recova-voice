# Public-source-only Recova API/migration image. Build from the repository root:
# docker build --platform linux/amd64 -f deploy/onnuri-jambonz-oss/Dockerfile.recova-backend .
# Python 3.13.14 and uv 0.8.15 are versioned and pinned to OCI index digests.
FROM --platform=linux/amd64 ghcr.io/astral-sh/uv:0.8.15@sha256:a5727064a0de127bdb7c9d3c1383f3a9ac307d9f2d8a391edc7896c54289ced0 AS uv
FROM --platform=linux/amd64 python:3.13.14-slim-trixie@sha256:6771159cd4fa5d9bba1258caf0b82e6b73458c694d178ad97c5e925c2d0e1a91 AS builder

COPY --from=uv /uv /usr/local/bin/uv
WORKDIR /build
COPY api/requirements.txt /build/api-requirements.txt
COPY pipecat /build/pipecat

RUN python -m venv /opt/venv \
    && uv pip install --python /opt/venv/bin/python --no-cache \
        --requirement /build/api-requirements.txt \
    && uv pip install --python /opt/venv/bin/python --no-cache \
        '/build/pipecat[azure,camb,cartesia,deepgram,elevenlabs,google,groq,mcp,openai,openrouter,sarvam,silero,soundfile,speechmatics]' \
    && uv pip install --python /opt/venv/bin/python --no-cache \
        transformers==5.5.0 python-multipart==0.0.30 msgpack==1.2.1 \
    && find /opt/venv -type d -name __pycache__ -prune -exec rm -rf '{}' + \
    && find /opt/venv -type f \( -name '*.pyc' -o -name '*.pyo' \) -delete

# Reuse the pinned builder filesystem so the legacy Docker builder does not need
# to copy a large cross-platform virtualenv layer.
FROM builder AS runtime

ENV PATH=/opt/venv/bin:$PATH \
    PYTHONPATH=/app \
    PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PIP_NO_INDEX=1 \
    UV_OFFLINE=1 \
    LOG_TO_FILE=false

WORKDIR /app
COPY --chown=65532:65532 api /app/api

# The runtime has no installer or dependency resolver; all artifacts are fixed at build time.
RUN rm -rf /usr/local/lib/python3.13/site-packages/pip* \
        /usr/local/lib/python3.13/ensurepip \
        /usr/local/bin/pip /usr/local/bin/pip3 /usr/local/bin/pip3.13 \
        /root/.cache /build /usr/local/bin/uv \
    && test -x /opt/venv/bin/alembic \
    && test -x /opt/venv/bin/uvicorn \
    && test -d /opt/venv/lib/python3.13/site-packages/pipecat \
    && test -f /app/api/alembic.ini \
    && test -f /app/api/services/telephony/onnuri_route_receipts.py \
    && python -c 'from api.services.telephony.onnuri_route_receipts import verify_route_chain'

USER 65532:65532
EXPOSE 8000
HEALTHCHECK --interval=30s --timeout=3s --start-period=10s --retries=3 \
    CMD ["python", "-c", "import urllib.request; urllib.request.urlopen('http://127.0.0.1:8000/api/v1/health', timeout=2).read()"]
CMD ["uvicorn", "api.app:app", "--host", "0.0.0.0", "--port", "8000"]
