    "rtpIngressAction": {
      "allOf": [
        {
          "$ref": "#/$defs/action"
        }
      ],
      "properties": {
        "control_id": {
          "const": "rtp_ingress"
        },
        "kind": {
          "const": "future_disable_or_delete"
        },
        "execution": {
          "const": "not_implemented"
        },
        "automatic_retry": {
          "const": false
        },
        "re_enable": {
          "const": false
        },
        "evidence_status": {
          "const": "waiting"
        }
      },
      "additionalProperties": false
    },
    "rtpEgressAction": {
      "allOf": [
        {
          "$ref": "#/$defs/action"
        }
      ],
      "properties": {
        "control_id": {
          "const": "rtp_egress"
        },
        "kind": {
          "const": "future_disable_or_delete"
        },
        "execution": {
          "const": "not_implemented"
        },
        "automatic_retry": {
          "const": false
        },
        "re_enable": {
          "const": false
        },
        "evidence_status": {
          "const": "waiting"
        }
      },
      "additionalProperties": false
