{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "onnuri-seoul-staging-phase-a/control-spec.schema.json",
  "title": "Onnuri Seoul staging Phase A provider-free control specification",
  "type": "object",
  "required": [
    "control_spec_version",
    "phase",
    "status",
    "controls",
    "actions"
  ],
  "properties": {
