          "$ref": "#/$defs/sourceFixture"
        }
      },
      "additionalProperties": false
    },
    "sipEgressControl": {
      "allOf": [
        {
          "$ref": "#/$defs/disabledControl"
        }
      ],
      "required": [
        "provenance"
      ],
      "properties": {
        "disabled": {
          "const": true
        },
        "phase": {
          "const": "A"
        },
        "deployment": {
          "const": "forbidden"
        },
        "evidence_status": {
          "const": "waiting"
        },
        "provenance": {
          "$ref": "#/$defs/outboundProxyProvenance"
        }
      },
      "additionalProperties": false
    },
    "rtpControl": {
      "allOf": [
        {
          "$ref": "#/$defs/disabledControl"
        }
      ],
      "required": [
        "peer",
        "ports",
        "status"
      ],
      "properties": {
        "disabled": {
          "const": true
        },
        "phase": {
          "const": "A"
        },
        "deployment": {
          "const": "forbidden"
        },
        "evidence_status": {
          "const": "waiting"
        },
        "peer": {
          "type": "null"
        },
        "ports": {
          "type": "null"
        },
        "status": {
          "const": "unpopulated"
        }
      },
      "additionalProperties": false
    },
    "sourceFixture": {
      "type": "object",
      "required": [
        "source_cidr",
        "fixture_only",
        "not_supplier_authoritative",
        "not_deployable"
      ],
      "properties": {
        "source_cidr": {
          "const": "61.78.32.184/32"
        },
        "fixture_only": {
          "const": true
        },
        "not_supplier_authoritative": {
          "const": true
        },
        "not_deployable": {
          "const": true
        }
      },
      "additionalProperties": false
    },
    "outboundProxyProvenance": {
      "type": "object",
      "required": [
        "outbound_proxy",
        "fixture_only",
        "not_supplier_authoritative",
        "not_deployable"
      ],
      "properties": {
        "outbound_proxy": {
          "const": "61.78.32.184:5060/UDP"
        },
        "fixture_only": {
          "const": true
        },
        "not_supplier_authoritative": {
          "const": true
        },
        "not_deployable": {
          "const": true
        }
      },
      "additionalProperties": false
    },
    "action": {
      "type": "object",
      "required": [
        "control_id",
        "kind",
        "execution",
        "automatic_retry",
        "re_enable",
        "evidence_status"
      ],
      "properties": {
        "kind": {
          "const": "future_disable_or_delete"
        },
        "execution": {
          "const": "not_implemented"
        },
        "automatic_retry": {
          "const": false
        },
        "re_enable": {
          "const": false
        },
        "evidence_status": {
          "const": "waiting"
        }
      }
    },
    "sipIngressAction": {
      "allOf": [
        {
          "$ref": "#/$defs/action"
        }
      ],
      "properties": {
