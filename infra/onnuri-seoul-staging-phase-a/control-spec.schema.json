      "const": "onnuri-seoul-staging-phase-a-control-spec-v1"
    },
    "phase": {
      "const": "A"
    },
    "status": {
      "const": "Waiting"
    },
    "controls": {
      "type": "object",
      "required": [
        "sip_ingress",
        "sip_egress",
        "rtp_ingress",
        "rtp_egress"
      ],
      "properties": {
        "sip_ingress": {
          "$ref": "#/$defs/sipIngressControl"
        },
        "sip_egress": {
          "$ref": "#/$defs/sipEgressControl"
        },
        "rtp_ingress": {
          "$ref": "#/$defs/rtpControl"
        },
        "rtp_egress": {
          "$ref": "#/$defs/rtpControl"
        }
      },
      "additionalProperties": false
    },
    "actions": {
      "type": "object",
      "required": [
        "contain_sip_ingress",
        "contain_sip_egress",
        "contain_rtp_ingress",
        "contain_rtp_egress"
      ],
      "properties": {
        "contain_sip_ingress": {
          "$ref": "#/$defs/sipIngressAction"
        },
        "contain_sip_egress": {
          "$ref": "#/$defs/sipEgressAction"
        },
        "contain_rtp_ingress": {
          "$ref": "#/$defs/rtpIngressAction"
        },
        "contain_rtp_egress": {
          "$ref": "#/$defs/rtpEgressAction"
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false,
  "$defs": {
    "disabledControl": {
      "type": "object",
      "required": [
        "disabled",
        "phase",
        "deployment",
        "evidence_status"
      ],
      "properties": {
        "disabled": {
          "const": true
        },
        "phase": {
          "const": "A"
        },
        "deployment": {
          "const": "forbidden"
        },
        "evidence_status": {
          "const": "waiting"
        }
      }
    },
    "sipIngressControl": {
      "allOf": [
        {
          "$ref": "#/$defs/disabledControl"
        }
      ],
      "required": [
        "fixture"
      ],
      "properties": {
        "disabled": {
          "const": true
        },
        "phase": {
          "const": "A"
        },
        "deployment": {
          "const": "forbidden"
        },
        "evidence_status": {
          "const": "waiting"
        },
