          "const": "sip_ingress"
        },
        "kind": {
          "const": "future_disable_or_delete"
        },
        "execution": {
          "const": "not_implemented"
        },
        "automatic_retry": {
          "const": false
        },
        "re_enable": {
          "const": false
        },
        "evidence_status": {
          "const": "waiting"
        }
      },
      "additionalProperties": false
    },
    "sipEgressAction": {
      "allOf": [
        {
          "$ref": "#/$defs/action"
        }
      ],
      "properties": {
